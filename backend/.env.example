# MongoDB Atlas connection details
db_user=your_mongodb_username
db_pwd=your_mongodb_password
db_host=your_cluster_address.mongodb.net
db_name=rozgaar

# Admin contact used by the app (e.g. for outgoing mail "from" address)
admin_mail=your_gmail_address@gmail.com
admin_mail_pass=your_gmail_app_password
admin_phone=+91XXXXXXXXXX
admin_pin=1234

# Twilio (for SMS notifications)
twilio_sid=your_twilio_account_sid
twilio_auth_token=your_twilio_auth_token

# Server port (optional, defaults to 3030)
PORT=3030
